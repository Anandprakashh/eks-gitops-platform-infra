project_name = "eks-gitops-platform"
environment  = "dev"
cluster_name = "eks-gitops-dev"
repository_name = "fastapi-app"

vpc_cidr = "10.0.0.0/16"

public_subnet_cidrs = [
  "10.0.1.0/24",
  "10.0.2.0/24"
]

private_subnet_cidrs = [
  "10.0.11.0/24",
  "10.0.12.0/24"
]

availability_zones = [
  "eu-west-2a",
  "eu-west-2b"
]

cluster_version = "1.35"
node_group_name = "general"
node_instance_types = ["t3.medium"]

desired_size = 2
min_size     = 1
max_size     = 2

capacity_type = "ON_DEMAND"